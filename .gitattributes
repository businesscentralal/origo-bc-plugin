# Normalize line endings across all platforms.
#
# Everything checked into git is stored with LF. On checkout:
#   - most text files: LF (works fine in VS Code, Notepad++, modern editors)
#   - shell scripts  : LF (required — bash on Linux/WSL/Azure agents refuses CRLF)
#   - PowerShell     : CRLF (pwsh on Windows tolerates LF, but Windows PowerShell
#                            5.1 is happier with CRLF; keep native for Windows users)
#   - binaries       : untouched

* text=auto eol=lf

# Explicit overrides
*.sh        text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Don't touch these
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.plugin    binary
